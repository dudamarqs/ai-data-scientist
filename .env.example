# Copie este arquivo para .env e preencha. O .env NUNCA vai para o Git.
#   cp .env.example .env

# Qual LLM usar: "gemini" (free tier do Google) ou "claude" (pago)
PROVEDOR_LLM=gemini

# Chave GRATUITA do Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Chave do Claude (opcional): https://console.anthropic.com
ANTHROPIC_API_KEY=

# Modelos (opcional - ja tem padrao)
# MODELO_GEMINI=gemini-2.5-flash
# MODELO_CLAUDE=claude-opus-4-8

# Limite de upload em MB (protege a memoria do servidor)
TAMANHO_MAXIMO_MB=50
